<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Bike App - Login</title>
</head>
<body class="bg-city">
    <div class="glass-container">
        <div class="card login-card">
            <h2>Bike Tracker</h2>
            <p class="subtitle">Temporary login placeholder for the demo</p>

            <% if (typeof error !== 'undefined' && error) { %>
                <p class="error-message"><%= error %></p>
            <% } %>

            <form action="/login" method="POST" class="login-form">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" placeholder="student@example.com" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input id="password" name="password" type="password" placeholder="Enter any password" required>
                </div>
                <button class="btn-orange" type="submit">Continue to Tracker</button>
            </form>

            <p class="login-note">This is a placeholder screen until the GitHub login merge is ready.</p>
        </div>
    </div>
</body>
</html>
