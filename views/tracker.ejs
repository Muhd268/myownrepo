<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/style.css">
    <title>Bike App - Track Ride</title>
</head>
<body class="bg-city">
    <div class="glass-container">
        <div class="card">
            <h2>Live Ride Tracker</h2>
            <div class="stats-grid">
                <div class="stat-box">
                    <p>Distance</p>
                    <h3 id="distance">0.00</h3><span>km</span>
                </div>
                <div class="stat-box">
                    <p>Calories</p>
                    <h3 id="calories">0</h3><span>kcal</span>
                </div>
            </div>
            <p id="status">Tracking Location...</p>
            <button class="btn-orange" onclick="location.href='/'">End Ride</button>
        </div>
    </div>

    <script>
        let totalDistance = 0;
        let lastCoords = null;

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371; // Earth radius in km
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon/2) * Math.sin(dLon/2);
            return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }

        navigator.geolocation.watchPosition((position) => {
            const { latitude, longitude } = position.coords;
            if (lastCoords) {
                const dist = calculateDistance(lastCoords.lat, lastCoords.lng, latitude, longitude);
                if (dist > 0.001) { // Filter out GPS jitter
                    totalDistance += dist;
                    document.getElementById('distance').innerText = totalDistance.toFixed(2);
                    // Standard cycling estimate: ~30 calories per km
                    document.getElementById('calories').innerText = Math.floor(totalDistance * 30);
                }
            }
            lastCoords = { lat: latitude, lng: longitude };
            document.getElementById('status').innerText = "Signal: Active";
        }, (err) => {
            document.getElementById('status').innerText = "Error: Enable GPS";
        }, { enableHighAccuracy: true });
    </script>
</body>
</html>